# ============================================================
# GeoOps — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# CockroachDB
DATABASE_URL=postgresql://user:pass@free-tier.cockroachlabs.cloud:26257/geoops?sslmode=verify-full

# JWT
JWT_SECRET=your-secret-key-min-32-chars

# App
PHX_HOST=your-app.gigalixirapp.com
PORT=4000
SECRET_KEY_BASE=generate-with-mix-phx-gen-secret

# Frontend URL (for CORS)
FRONTEND_URL=https://your-app.pages.dev
